<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO"><appender-ref ref="CONSOLE"/></root>
    </springProfile>

    <springProfile name="prod">
        <!-- Archivo rotativo — A7 Trazabilidad auditoria -->
        <appender name="FILE_VENTAS" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/ventas.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/ventas.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <maxHistory>1825</maxHistory><!-- 5 años — requisito SUNAT -->
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <appender name="FILE_CONTINGENCIA" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/contingencia.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/contingencia.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <maxHistory>365</maxHistory>
            </rollingPolicy>
            <encoder><pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</pattern></encoder>
        </appender>

        <logger name="com.Veterinaria.Mejia.services.VentaService"
                level="INFO" additivity="false">
            <appender-ref ref="FILE_VENTAS"/>
        </logger>
        <logger name="com.Veterinaria.Mejia.services.ContingenciaService"
                level="INFO" additivity="false">
            <appender-ref ref="FILE_CONTINGENCIA"/>
        </logger>

        <root level="WARN">
            <appender-ref ref="FILE_VENTAS"/>
        </root>
    </springProfile>
</configuration>
